{
  "manifest_version": 3,
  "name": "Volume Booster – Frutiger Aero",
  "version": "1.0.0",
  "description": "Boost and control page volume from 0% to 300%.",
  "action": {
    "default_title": "Abrir Volume Booster",
    "default_icon": {
      "16": "icon16x16.png",
      "32": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "icons": {
    "16": "icon16x16.png",
    "32": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "permissions": ["storage", "scripting", "tabs"],
  "host_permissions": ["*://*/*"],
  "commands": {
    "toggle-panel": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y"
      },
      "description": "Abrir o mostrar el panel"
    },
    "increase-volume": {
      "suggested_key": {
        "default": "Ctrl+Shift+Up"
      },
      "description": "Subir volumen"
    },
    "decrease-volume": {
      "suggested_key": {
        "default": "Ctrl+Shift+Down"
      },
      "description": "Bajar volumen"
    }
  },
  "background": {
    "service_worker": "background.js"
  }
}
